<ChatListItem@ButtonBehavior+BoxLayout>:
    size_hint_y: None
    height: 70
    padding: [15, 10]
    spacing: 15
    username: "Unknown User"
    last_msg: "..."
    status: "OFFLINE"

    canvas.before:
        Color:
            rgba: 0.3, 1.0, 0.3, 0.1 if self.state == 'normal' else 0.2
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.3, 1.0, 0.3, 0.3
        Line:
            points: self.x, self.y, self.right, self.y
            width: 1

    BoxLayout:
        orientation: 'vertical'
        Label:
            text: f"> {root.username}"
            font_size: '16sp'
            halign: 'left'
            text_size: self.size
            color: 0.3, 1.0, 0.3, 1
        Label:
            text: root.last_msg
            font_size: '12sp'
            halign: 'left'
            text_size: self.size
            color: 0.1, 0.5, 0.1, 1

    Label:
        text: f"[{root.status}]"
        size_hint_x: None
        width: 80
        halign: 'right'
        text_size: self.size
        font_size: '10sp'
        color: (0.3, 1.0, 0.3, 1) if root.status == "ONLINE" else (0.5, 0.5, 0.5, 1)

<InboxScreen>:
    name: 'inbox'

    BoxLayout:
        orientation: 'vertical'
        padding: [10, 10, 10, 10]
        spacing: 10

        # Header
        BoxLayout:
            size_hint_y: None
            height: 40
            Label:
                text: "> ACTIVE_SESSIONS"
                font_size: '18sp'
                halign: 'left'
                text_size: self.size
                color: 0.3, 1.0, 0.3, 1

            TermButton:
                text: "[ LOGOUT ]"
                size_hint_x: None
                width: 100
                on_press: app.root.current = 'login'

        # Inbox List
        ScrollView:
            BoxLayout:
                id: inbox_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height

                ChatListItem:
                    username: "root_admin"
                    last_msg: "System update complete."
                    status: "ONLINE"
                    on_press: root.open_chat(self.username)

                ChatListItem:
                    username: "cyber_ghost"
                    last_msg: "Did you check the logs?"
                    status: "OFFLINE"
                    on_press: root.open_chat(self.username)

                ChatListItem:
                    username: "byte_hacker"
                    last_msg: "Incoming connection..."
                    status: "ONLINE"
                    on_press: root.open_chat(self.username)

        # Footer
        BoxLayout:
            size_hint_y: None
            height: 50

            TermButton:
                text: "[ NEW_SESSION ]"
                on_press: print("Search for new user logic")
