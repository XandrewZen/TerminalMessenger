# Global Styles and Custom Terminal Components

<TermInput@TextInput>:
    background_color: 0, 0, 0, 0
    foreground_color: 0.3, 1.0, 0.3, 1
    cursor_color: 0.3, 1.0, 0.3, 1
    hint_text_color: 0.1, 0.4, 0.1, 1
    padding: [10, 10]
    size_hint_y: None
    height: 45
    multiline: False
    canvas.after:
        Color:
            rgba: 0.3, 1.0, 0.3, 0.3
        Line:
            points: self.x, self.y, self.x + self.width, self.y
            width: 1.0

<TermButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: (0.3, 1.0, 0.3, 1) if self.state == 'normal' else (0.1, 0.5, 0.1, 1)
    size_hint_y: None
    height: 50
    canvas.before:
        Color:
            rgba: (0.3, 1.0, 0.3, 1) if self.state == 'normal' else (0.1, 0.5, 0.1, 1)
        Line:
            width: 1.0
            rectangle: self.x, self.y, self.width, self.height

<Screen>:
    canvas.before:
        Color:
            rgba: 0.01, 0.01, 0.01, 1
        Rectangle:
            pos: self.pos
            size: self.size
