<LoginScreen>:
    name: 'login'
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 10

        Label:
            text: "TerminalMessenger"
            font_size: 32

        TextInput:
            hint_text: "Username"
            multiline: False

        TextInput:
            hint_text: "Password"
            multiline: False
            password: True

        Button:
            text: "Login"
            on_press: app.root.current = 'chat'

        Button:
            text: "Register"
            on_press: app.root.current = 'register'